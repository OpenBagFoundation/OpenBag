[codespell]
skip = *.svg,*.png,*.html,*.json,*.yaml,*.yml,*.lock,*.min.js,.git
ignore-words-list = ser,sinal,saem,vai,momento,foto,vetor,anual,fases,fase,falso,tese,mede,repete,te,inicial,itesm,vetores,crach,crachá,nao,seu,sua,os,as,ois,fim,tao,em,ja,esta,este,des,pra,pro,com,sem,por,sob,ans,ist,ot,vista,pano,tens,ente,instale,comando,oficial,caracteres,dominante,nome,residencial,atual,validade,cliente,profissional,comandos,responde,componentes,cursos,eles,absorve,confidencial,auxiliar,comercial,ortogonal,pares,termo,exata,meu,autor,diagramas,itens,inicialize,registre,controle,essencial,valide
quiet-level = 2
