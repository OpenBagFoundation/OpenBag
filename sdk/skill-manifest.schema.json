{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://openbag.foundation/schemas/skill-manifest-v1.json",
  "title": "OpenBag Skill Manifest",
  "description": "Schema for SKILL.yaml manifests describing OpenBag Agent skills. Inspired by OpenClaw SKILL.md format.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "version", "description", "author", "license", "permissions"],
  "properties": {
    "name": {
      "type": "string",
      "description": "Unique skill identifier. Lowercase, hyphen-separated, prefixed 'skill-'.",
      "pattern": "^skill-[a-z0-9][a-z0-9-]{2,40}$",
      "examples": ["skill-verify", "skill-sentinel", "skill-finance"]
    },
    "version": {
      "type": "string",
      "description": "Semantic version (semver 2.0.0).",
      "pattern": "^\\d+\\.\\d+\\.\\d+(-[0-9A-Za-z.-]+)?(\\+[0-9A-Za-z.-]+)?$",
      "examples": ["0.1.0", "1.0.0", "2.3.4-beta.1"]
    },
    "display_name": {
      "type": "string",
      "description": "Human-readable name shown in agent UI. Localizable via i18n object.",
      "maxLength": 60
    },
    "description": {
      "type": "string",
      "description": "Short (1-2 sentence) description of what the skill does. Required for registry listing.",
      "minLength": 20,
      "maxLength": 500
    },
    "author": {
      "type": "object",
      "description": "Skill author/maintainer information.",
      "required": ["name"],
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 100 },
        "email": { "type": "string", "format": "email" },
        "url": { "type": "string", "format": "uri" },
        "organization": { "type": "string" }
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX identifier. Open-source licenses only (Foundation policy).",
      "enum": ["MIT", "Apache-2.0", "BSD-3-Clause", "BSD-2-Clause", "MPL-2.0", "ISC", "GPL-3.0-or-later", "AGPL-3.0-or-later", "Unlicense", "CC0-1.0"]
    },
    "min_agent_version": {
      "type": "string",
      "description": "Minimum required OpenBag Agent version (semver).",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "default": "0.1.0"
    },
    "platforms": {
      "type": "array",
      "description": "Supported runtime platforms.",
      "items": { "enum": ["ios", "android", "web", "desktop"] },
      "minItems": 1,
      "uniqueItems": true,
      "default": ["ios", "android"]
    },
    "category": {
      "type": "string",
      "description": "Primary category for ClawHub-BR registry browsing.",
      "enum": ["core", "verification", "safety", "finance", "health", "education", "legal", "civic", "utility", "experimental"]
    },
    "tags": {
      "type": "array",
      "description": "Searchable tags for ClawHub-BR.",
      "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{0,30}$" },
      "maxItems": 10,
      "uniqueItems": true
    },
    "permissions": {
      "type": "object",
      "description": "Capabilities the skill needs to function. User must approve at install. Principle of least privilege enforced.",
      "additionalProperties": false,
      "properties": {
        "ble": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "scan": { "type": "boolean", "description": "Scan for BLE beacons (read-only, passive)." },
            "advertise": { "type": "boolean", "description": "Broadcast BLE advertisements (worker bag/badge only)." },
            "connect": { "type": "boolean", "description": "Establish GATT connections (rare; firmware updates only)." }
          }
        },
        "nfc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read": { "type": "boolean", "description": "Read NFC tags (citizen verification)." },
            "write": { "type": "boolean", "description": "Write to NFC tags (factory provisioning only — restricted)." }
          }
        },
        "location": {
          "type": "object",
          "additionalProperties": false,
          "required": ["precision"],
          "properties": {
            "precision": {
              "enum": ["geohash5", "geohash7", "exact"],
              "description": "Maximum precision allowed. geohash5 (~5km) for routine, exact only for active route or panic."
            },
            "background": {
              "type": "boolean",
              "default": false,
              "description": "Continue location reporting in background. Requires explicit user re-consent every 30 days."
            }
          }
        },
        "notifications": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "local": { "type": "boolean", "description": "Show local on-device notifications." },
            "push": { "type": "boolean", "description": "Receive remote push notifications via APNs/FCM." }
          }
        },
        "network": {
          "type": "object",
          "additionalProperties": false,
          "required": ["domains"],
          "properties": {
            "domains": {
              "type": "array",
              "description": "Whitelisted hostnames. No wildcards. Foundation-allowed domains only.",
              "items": { "type": "string", "pattern": "^[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?(\\.[a-z0-9]([a-z0-9-]{0,61}[a-z0-9])?)+$" },
              "minItems": 1,
              "maxItems": 20,
              "uniqueItems": true
            },
            "methods": {
              "type": "array",
              "items": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
              "default": ["GET", "POST"],
              "uniqueItems": true
            }
          }
        },
        "storage": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "encrypted_local": { "type": "boolean", "description": "Use SQLCipher local store (default for sensitive data)." },
            "max_mb": { "type": "integer", "minimum": 1, "maximum": 500, "description": "Maximum storage quota in MB." }
          }
        },
        "biometric": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "verify": { "type": "boolean", "description": "Trigger device-level biometric (FaceID/fingerprint) for confirmation." }
          }
        },
        "camera": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "qr_only": { "type": "boolean", "description": "Camera limited to QR/barcode scanning (no photo capture)." },
            "photo": { "type": "boolean", "description": "Full photo capture (requires explicit user consent each session)." }
          }
        },
        "skills_ipc": {
          "type": "array",
          "description": "Other skills this skill may invoke via local IPC.",
          "items": { "type": "string", "pattern": "^skill-[a-z0-9][a-z0-9-]{2,40}$" },
          "uniqueItems": true
        }
      }
    },
    "hooks": {
      "type": "object",
      "description": "Lifecycle hook entry points.",
      "additionalProperties": false,
      "properties": {
        "on_install": { "type": "string", "description": "Path to install handler script." },
        "on_activate": { "type": "string", "description": "Path to activation handler script." },
        "on_deactivate": { "type": "string", "description": "Path to deactivation handler script." },
        "on_uninstall": { "type": "string", "description": "Path to uninstall handler (cleanup)." }
      }
    },
    "skills_required": {
      "type": "array",
      "description": "Skills that MUST be installed for this skill to function.",
      "items": { "type": "string", "pattern": "^skill-[a-z0-9][a-z0-9-]{2,40}(@.+)?$" },
      "uniqueItems": true
    },
    "skills_optional": {
      "type": "array",
      "description": "Skills that ENHANCE this skill if also installed.",
      "items": { "type": "string", "pattern": "^skill-[a-z0-9][a-z0-9-]{2,40}(@.+)?$" },
      "uniqueItems": true
    },
    "ui": {
      "type": "object",
      "description": "User interface integration with the OpenBag Agent shell.",
      "additionalProperties": false,
      "properties": {
        "has_widget": { "type": "boolean", "default": false, "description": "Skill provides a home-screen widget." },
        "widget_size": {
          "enum": ["compact", "medium", "full"],
          "description": "Widget footprint. compact=1row, medium=2row, full=fullscreen."
        },
        "has_settings": { "type": "boolean", "default": false, "description": "Skill provides a settings panel." },
        "icon": { "type": "string", "description": "Path to skill icon (SVG preferred, 256x256 PNG fallback)." },
        "color": { "type": "string", "pattern": "^#[0-9A-Fa-f]{6}$", "description": "Skill accent color (hex)." }
      }
    },
    "i18n": {
      "type": "object",
      "description": "Localized strings. Keys are BCP-47 language tags. Default 'pt-BR' if omitted.",
      "patternProperties": {
        "^[a-z]{2}(-[A-Z]{2})?$": {
          "type": "object",
          "properties": {
            "display_name": { "type": "string" },
            "description": { "type": "string" }
          }
        }
      }
    },
    "registry": {
      "type": "object",
      "description": "ClawHub-BR registry metadata.",
      "additionalProperties": false,
      "properties": {
        "homepage": { "type": "string", "format": "uri" },
        "repository": { "type": "string", "format": "uri" },
        "issues": { "type": "string", "format": "uri" },
        "audit_url": { "type": "string", "format": "uri", "description": "Link to public security audit (required for 'core' category)." }
      }
    },
    "experimental": {
      "type": "boolean",
      "default": false,
      "description": "Mark as experimental. Shows warning to users at install time."
    }
  }
}
